# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# Required: your ElevenLabs API key (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your_api_key_here

# Optional: pin a specific voice by ID (skips the by-name lookup).
# Leave blank to resolve the default voice "Alex" by name automatically.
# VOICE_ID=

# Optional: override the TTS model. Default is eleven_flash_v2_5 (cheapest, ~0.5 credits/char).
# MODEL_ID=eleven_flash_v2_5
